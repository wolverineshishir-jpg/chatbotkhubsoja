PROJECT_NAME=SaaS Chat Automation Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-to-a-long-random-string-with-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
DOCS_ENABLED=true
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ALLOWED_HOSTS=["*"]
# Docker Compose defaults:
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=automation
# For running without Docker, you can instead set:
# DATABASE_URL=mysql+pymysql://app:app@127.0.0.1:3306/automation
DATABASE_URL=
# Docker Compose defaults:
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# For running without Docker, you can instead set:
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION=v23.0
FACEBOOK_GRAPH_API_BASE_URL=https://graph.facebook.com
FACEBOOK_OAUTH_DIALOG_URL=https://www.facebook.com/dialog/oauth
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:5173/connections/facebook/callback
FACEBOOK_HTTP_TIMEOUT_SECONDS=30
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_HTTP_TIMEOUT_SECONDS=30
WHATSAPP_VERIFY_SIGNATURE=true
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=
OPENAI_TIMEOUT_SECONDS=30
LLM_DEFAULT_PROVIDER=internal
LLM_DEFAULT_MODEL=internal-reply-model-v1
OPENAI_REPLY_PRIMARY_MODEL=gpt-5.4-nano
OPENAI_REPLY_FALLBACK_MODEL=gpt-5.4-mini
OPENAI_REPLY_CONFIDENCE_THRESHOLD=0.55
AI_TOKEN_DEBIT_ENABLED=true
